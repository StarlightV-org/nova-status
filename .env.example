# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
POSTGRES_PORT=5656

# Image tags (override for registry pulls)
# Published releases: docker.io/starlightv/nova-status-app:<tag>
NOVA_APP_IMAGE=starlightv/nova-status-app:latest
NOVA_MIGRATE_IMAGE=starlightv/nova-status-migrate:latest

# App port
APP_PORT=3000

# Auth (required at runtime)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me
JWT_SECRET=change-me
BETTER_AUTH_GITHUB_CLIENT_ID=
BETTER_AUTH_GITHUB_CLIENT_SECRET=

# Local dev (bun run dev) — use host port from POSTGRES_PORT
# DATABASE_URL=postgresql://postgres:password@localhost:5656/postgres
