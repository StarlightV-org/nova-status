{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"declarationMap": true,
		"incremental": true,
		"noEmit": true,
		"lib": ["dom", "dom.iterable", "ES2022"],
		"module": "ESNext",
		"paths": {
			"~/*": ["./src/*"],
		},
	},
	"include": ["src", "**/*.ts"],
	"exclude": ["node_modules", "dist"],
}
