{
	"name": "nova-status",
	"private": true,
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"check": "turbo run check",
		"check:unsafe": "turbo run check:unsafe",
		"check:write": "turbo run check:write",
		"dk": "drizzle-kit --config=./packages/db/drizzle.config.ts",
		"dev": "turbo run dev",
		"dev:web": "cd apps/nova-web && bun dev",
		"dev:socket": "cd apps/nova-socket && bun dev",
		"docker:build:app": "docker build -f Dockerfile.app -t nova-status-app:latest .",
		"docker:build:migrate": "docker build -f Dockerfile.migrate -t nova-status-migrate:latest .",
		"docker:build": "bun run docker:build:app && bun run docker:build:migrate"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.11.2",
		"@better-auth/passkey": "1.6.16",
		"@fastify/express": "^4.0.6",
		"@novastatus/db": "workspace:*",
		"@novastatus/env": "workspace:*",
		"@novastatus/lib": "workspace:*",
		"@starlightv-org/print": "^0.1.2",
		"@t3-oss/env-core": "^0.13.11",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.101.0",
		"@trpc/client": "^11.17.0",
		"@trpc/react-query": "^11.17.0",
		"@trpc/server": "^11.17.0",
		"better-auth": "1.6.16",
		"bun": "^1.3.14",
		"chalk": "^5.6.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"ioredis": "^5.11.1",
		"jsonwebtoken": "^9.0.3",
		"lucide-react": "^1.17.0",
		"mongodb": "^7.3.0",
		"motion": "^12.40.0",
		"mysql2": "^3.22.5",
		"next": "^16.2.9",
		"pg": "^8.21.0",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.9",
		"radix-ui": "^1.5.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"server-only": "^0.0.1",
		"shadcn": "^4.11.0",
		"short-unique-id": "^5.3.2",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3",
		"sonner": "^2.0.7",
		"superjson": "^2.2.6",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.9.2",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.10",
		"postcss": "^8.5.15",
		"prettier": "^3.8.4",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4.3.0",
		"turbo": "^2.9.17",
		"typescript": "^6.0.3"
	}
}
