{
	"name": "nova-monitor",
	"private": true,
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"check": "turbo run check",
		"check:unsafe": "turbo run check:unsafe",
		"check:write": "turbo run check:write",
		"dk": "drizzle-kit --config=./packages/db/drizzle.config.ts",
		"dev": "turbo run dev",
		"dev:web": "cd apps/nova-web && bun dev",
		"dev:socket": "cd apps/nova-socket && bun dev",
		"lint": "turbo run check",
		"preview": "turbo run preview",
		"start": "turbo run start",
		"typecheck": "turbo run typecheck"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.7.2",
		"@fastify/express": "^4.0.6",
		"@t3-oss/env-core": "^0.13.11",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.69.0",
		"@trpc/client": "^11.0.0",
		"@trpc/react-query": "^11.0.0",
		"@trpc/server": "^11.0.0",
		"better-auth": "^1.3",
		"chalk": "^5.6.2",
		"date-fns": "^4.4.0",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"jsonwebtoken": "^9.0.3",
		"next": "^16.2.7",
		"postgres": "^3.4.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"server-only": "^0.0.1",
		"short-unique-id": "^5.3.2",
		"socket.io": "^4.8.3",
		"superjson": "^2.2.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@tailwindcss/postcss": "^4.0.15",
		"@types/bun": "latest",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.0.0",
		"drizzle-kit": "^0.31.10",
		"postcss": "^8.5.3",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4.0.15",
		"turbo": "latest",
		"typescript": "^6.0.3"
	}
}
