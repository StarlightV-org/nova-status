{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"declarationMap": true,

		/* Bundled projects */
		"lib": ["dom", "dom.iterable", "ES2022"],
		"noEmit": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "preserve",

		"incremental": true,
		"paths": {
			"~/*": ["./src/*"],
		},
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"],
}
