{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"declarationMap": true,
		"noEmit": true,
		"lib": ["dom", "dom.iterable", "ES2022"],
		"module": "ESNext",
		"paths": {
			"~/*": ["./src/*"],
			"~/schema": ["../db/src/schema.ts"],
			"~/db": ["../db/src/index.ts"],
			"~/db/*": ["../db/src/*"],
			"~/env": ["../env/src/env.ts"],
			"~/print": ["../print/src/print.ts"],
		},
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"],
}
